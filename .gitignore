# Release packaging folder and its output (local build tooling, not part of the project)
.dist/

# Runtime directories (created automatically at first run; not part of the project)
Config/
Logs/
Reports/

# Runtime files (written by the scripts during execution)
hosts.conf
conf/dashboard.status

# AI assistant working notes (local to the maintainer; not part of the public project)
CLAUDE.md

# Planning documents (local to the maintainer; not part of the public project)
docs/plans/

# IDE settings
.vscode/

# Windows thumbnail cache
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin
$RECYCLE.BIN/

# PowerShell
*.ps1xml

# Credentials and secrets (never commit encrypted credential files)
*.xml

# Log files
*.log

# Temporary files
*.tmp
*.temp
~$*

# Editor backups
*~
*.bak
*.swp
*.swo
